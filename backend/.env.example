# Server
PORT=8080
GIN_MODE=debug
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# Database
DB_URL=postgres://postgres:secret@localhost:5432/docverify?sslmode=disable

# Auth
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRY_HOURS=24

# Storage: s3 (MinIO/R2) or db (PostgreSQL blobs — no card needed)
STORAGE_DRIVER=s3
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=docverify
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_SSL=false

# Upload limits
MAX_UPLOAD_MB=25

# Rate limit (public verify)
VERIFY_RATE_LIMIT=30
VERIFY_RATE_BURST=10

# Optional: extra CORS origins (comma-separated), e.g. Vercel preview URLs
# ALLOWED_ORIGINS=https://docverify.vercel.app,https://docverify-git-main-you.vercel.app
